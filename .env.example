# Copy this file to .env and fill in the values
# cp .env.example .env

# ─── Database ────────────────────────────────────────────────
POSTGRES_DB=tiktokshop_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_PORT=5432

# ─── Backend ─────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
BACKEND_PORT=8080

# ─── JWT (CHANGE IN PRODUCTION — min 64 random chars) ────────
JWT_SECRET_KEY=change_this_to_a_random_secret_key_at_least_64_chars_long_for_production_use
JWT_ISSUER=TikTokShop
JWT_AUDIENCE=TikTokShopClient
JWT_ACCESS_TOKEN_MINUTES=60
JWT_REFRESH_TOKEN_DAYS=7

# ─── PgAdmin (optional, start with: docker compose --profile tools up) ──
PGADMIN_EMAIL=admin@tiktokshop.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ─── TikTok (configure in Phase 7) ──────────────────────────
# TIKTOK_APP_KEY=
# TIKTOK_APP_SECRET=
# TIKTOK_REDIRECT_URI=https://yourdomain.com/api/tiktok-shops/callback
# TIKTOK_WEBHOOK_URL=https://yourdomain.com/api/webhooks/tiktok
# TIKTOK_REGION=GLOBAL
